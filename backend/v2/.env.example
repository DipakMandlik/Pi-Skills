# AI Skill Management Platform — Backend v2
# Copy to .env.local and replace placeholder values.

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
DEBUG=false
ENVIRONMENT=development

# JWT Authentication
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=__REQUIRED_RANDOM_64_CHAR_HEX__
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Database
# SQLite for development (default). Use PostgreSQL for production.
# PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/pi_skills
DATABASE_URL=sqlite+aiosqlite:///./backend_v2_dev.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (optional — leave empty for in-memory rate limiting)
REDIS_URL=
REDIS_PERM_TTL=60
REDIS_MODEL_TTL=300

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_15MIN=5

# Request Limits (bytes)
MAX_REQUEST_BODY_BYTES=10240
MAX_FILE_UPLOAD_BYTES=5242880

# Bootstrap Seed (set to true for first-run demo data)
ENABLE_BOOTSTRAP_SEED=false
