# Local development environment template
# Copy to .env.local and replace placeholder values.

# Frontend
GEMINI_API_KEY=__REQUIRED__
VITE_MCP_BASE_URL=http://localhost:5000

# MCP bridge runtime
MCP_HOST=0.0.0.0
MCP_PORT=5000
MCP_LOG_LEVEL=INFO
MCP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
MCP_AUTH_REQUIRED=true
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_MAX_ARGUMENTS_BYTES=50000
MCP_MAX_ARGUMENT_LENGTH=10000
MCP_SESSION_DATABASE_URL=sqlite:///./server_mcp_sessions.db

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=__REQUIRED_RANDOM_64_CHAR_HEX__

# Snowflake credentials
SNOWFLAKE_ACCOUNT=__REQUIRED__
SNOWFLAKE_USER=__REQUIRED__
SNOWFLAKE_PASSWORD=__REQUIRED__
SNOWFLAKE_ROLE=__REQUIRED__
SNOWFLAKE_WAREHOUSE=__REQUIRED__
SNOWFLAKE_DATABASE=__REQUIRED__
SNOWFLAKE_SCHEMA=__REQUIRED__

# Optional: reduce local connector warning noise
SNOWFLAKE_LOG_LEVEL=ERROR
SUPPRESS_CLOUD_METADATA_PROBES=true

# SQL guardrails
SQL_SAFETY_MODE=dev
SQL_DEFAULT_ROW_LIMIT=1000
SQL_MAX_ROWS=5000
SQL_TIMEOUT_SECONDS=60
