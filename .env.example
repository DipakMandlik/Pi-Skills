# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyAkocnSSc4qzAfc9jPS6Vzt2oYjxTHyMW0"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Frontend runtime target for MCP bridge service.
VITE_MCP_BASE_URL="http://localhost:5000"
# Frontend MCP request timeout in milliseconds.
VITE_MCP_REQUEST_TIMEOUT_MS="30000"
# Optional: focus explorer hydration to one database for faster startup on large accounts.
# Example: VITE_EXPLORER_DATABASE="BANKING"
VITE_EXPLORER_DATABASE=""

# Snowflake credentials for MCP server (local development).
# Use a least-privileged service user and never commit real secrets.
SNOWFLAKE_ACCOUNT="WRBPMWS-WQ81670"
SNOWFLAKE_USER="PIQLENS_APP_USER"
SNOWFLAKE_PASSWORD="Snowflake@1234"
SNOWFLAKE_ROLE="ACCOUNTADMIN"
SNOWFLAKE_WAREHOUSE="COMPUTE_WH"
SNOWFLAKE_DATABASE="BANKING"
SNOWFLAKE_SCHEMA="BRONZE"

# MCP server runtime settings.
MCP_HOST="0.0.0.0"
MCP_PORT="5000"
MCP_LOG_LEVEL="INFO"
MCP_CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001"
# Third-party snowflake/urllib logs threshold: DEBUG | INFO | WARNING | ERROR.
SNOWFLAKE_LOG_LEVEL="ERROR"
# Disable cloud instance metadata probing in local environments.
SUPPRESS_CLOUD_METADATA_PROBES="true"

# SQL safety profiles:
# - dev: permits read-focused statements and blocks destructive operations.
# - prod: strict read-only profile (SELECT/SHOW/DESCRIBE).
SQL_SAFETY_MODE="dev"
SQL_DEFAULT_ROW_LIMIT="1000"
SQL_MAX_ROWS="5000"
SQL_TIMEOUT_SECONDS="60"
