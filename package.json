{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "mcp:install": "py -3.12 -m pip install -r server/requirements.txt || python -m pip install -r server/requirements.txt || py -m pip install -r server/requirements.txt || %LOCALAPPDATA%\\Programs\\Python\\Python312\\python.exe -m pip install -r server/requirements.txt || %LOCALAPPDATA%\\Microsoft\\WindowsApps\\python.exe -m pip install -r server/requirements.txt",
    "mcp:dev": "py -3.12 -m server.main || python -m server.main || py -m server.main || %LOCALAPPDATA%\\Programs\\Python\\Python312\\python.exe -m server.main || %LOCALAPPDATA%\\Microsoft\\WindowsApps\\python.exe -m server.main",
    "backend:install": "py -3.12 -m pip install -r backend/requirements.txt || python -m pip install -r backend/requirements.txt || py -m pip install -r backend/requirements.txt",
    "backend:dev": "py -3.12 -m backend.main || python -m backend.main || py -m backend.main || %LOCALAPPDATA%\\Programs\\Python\\Python312\\python.exe -m backend.main || %LOCALAPPDATA%\\Microsoft\\WindowsApps\\python.exe -m backend.main",
    "dev:full": "concurrently \"npm run dev\" \"npm run mcp:dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true});\"",
    "clean:all": "powershell -ExecutionPolicy Bypass -File deployment/scripts/clean-run-test-all.ps1 -CleanOnly",
    "run:test:all:one": "powershell -ExecutionPolicy Bypass -File deployment/scripts/clean-run-test-all.ps1",
    "lint": "tsc --noEmit",
    "test:api": "node docs/tester/run-api-tests.js --base-url http://localhost:8000",
    "test:auth:e2e": "powershell -ExecutionPolicy Bypass -File docs/tester/auth-e2e.ps1",
    "test:api:auth": "node docs/tester/run-api-tests.js --base-url http://localhost:8000 --phase auth",
    "test:api:adminai": "node docs/tester/run-api-tests.js --base-url http://localhost:8000 --phase adminai",
    "test:api:governance": "node docs/tester/run-api-tests.js --base-url http://localhost:8000 --phase governance",
    "test:api:perf": "node docs/tester/run-api-tests.js --base-url http://localhost:8000 --phase perf",
    "test:api:adminai:ci": "node docs/tester/run-api-tests.js --base-url http://localhost:8000 --phase adminai --results-tag ci",
    "test:api:governance:ci": "node docs/tester/run-api-tests.js --base-url http://localhost:8000 --phase governance --results-tag ci",
    "test:api:perf:ci": "node docs/tester/run-api-tests.js --base-url http://localhost:8000 --phase perf --results-tag ci",
    "test:security": "node docs/tester/security-attacks.js --base-url http://localhost:8000",
    "test:logs": "node docs/tester/validate-audit-logs.js --base-url http://localhost:8000",
    "test:ui:rbac": "node docs/tester/ui-rbac-route-guard.mjs",
    "test:ui:e2e": "node docs/tester/ui-e2e-playwright.mjs",
    "test:unit:js": "vitest run --coverage",
    "test:unit:js:watch": "vitest",
    "test:unit:py": "py -3.12 -m pytest apps/api/tests apps/mcp/tests -q || python -m pytest apps/api/tests apps/mcp/tests -q",
    "test:startup:security": "py -3.12 -m pytest apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_weak_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_missing_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_placeholder_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_emit_structured_remediation_messages apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_weak_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_missing_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_placeholder_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_emit_structured_remediation_messages -q || python -m pytest apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_weak_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_missing_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_placeholder_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_emit_structured_remediation_messages apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_weak_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_missing_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_placeholder_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_emit_structured_remediation_messages -q",
    "test:startup:security:ci": "python -m pytest apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_weak_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_missing_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_reject_placeholder_jwt_secret apps/mcp/tests/test_server_main_security.py::test_startup_checks_emit_structured_remediation_messages apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_weak_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_missing_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_reject_placeholder_jwt_secret apps/mcp/tests/test_apps_mcp_startup_security.py::test_apps_mcp_startup_checks_emit_structured_remediation_messages -q",
    "test:unit:py:cov": "py -3.12 -m pytest --cov=apps --cov=backend --cov=server --cov-report=term-missing --cov-report=xml --cov-report=html apps/api/tests apps/mcp/tests || python -m pytest --cov=apps --cov=backend --cov=server --cov-report=term-missing --cov-report=xml --cov-report=html apps/api/tests apps/mcp/tests",
    "trace:generate": "py -3.12 docs/create_trace.py || python docs/create_trace.py",
    "trace:append": "py -3.12 docs/create_trace.py --append || python docs/create_trace.py --append",
    "test:full": "npm run test:api && npm run test:security && npm run test:logs",
    "test:full:expanded": "npm run test:api && npm run test:api:adminai && npm run test:api:governance && npm run test:api:perf && npm run test:security && npm run test:logs && npm run test:ui:rbac",
    "docker:build": "docker compose -f deployment/docker/docker-compose.yml build",
    "docker:up": "docker compose -f deployment/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f deployment/docker/docker-compose.yml down",
    "docker:logs": "docker compose -f deployment/docker/docker-compose.yml logs -f",
    "docker:restart": "docker compose -f deployment/docker/docker-compose.yml restart",
    "build:prod": "npm run build && docker compose -f deployment/docker/docker-compose.yml build",
    "start:prod": "docker compose -f deployment/docker/docker-compose.yml up -d --scale backend=2",
    "deploy": "npm run build:prod && npm run start:prod",
    "db:migrate": "py -3.12 -m alembic -c alembic.ini upgrade head || python -m alembic -c alembic.ini upgrade head",
    "db:migrate:revision": "py -3.12 -m alembic -c alembic.ini revision --autogenerate -m",
    "db:migrate:skills": "py -3.12 -m backend.scripts.migrate_skill_registry || python -m backend.scripts.migrate_skill_registry",
    "db:migrate:snowflake": "py -3.12 -m backend.scripts.migrate_to_snowflake --sqlite-path backend_dev.db --sf-account %SNOWFLAKE_ACCOUNT% --sf-user %SNOWFLAKE_USER% --sf-password %SNOWFLAKE_PASSWORD% --sf-role %SNOWFLAKE_ROLE% --sf-warehouse %SNOWFLAKE_WAREHOUSE% --sf-database PI_OPTIMIZED",
    "db:migrate:snowflake:dry-run": "py -3.12 -m backend.scripts.migrate_to_snowflake --sqlite-path backend_dev.db --sf-account %SNOWFLAKE_ACCOUNT% --sf-user %SNOWFLAKE_USER% --sf-password %SNOWFLAKE_PASSWORD% --sf-role %SNOWFLAKE_ROLE% --sf-warehouse %SNOWFLAKE_WAREHOUSE% --sf-database PI_OPTIMIZED --dry-run",
    "db:seed": "docker compose -f deployment/docker/docker-compose.yml exec backend python -c \"from backend.main import _seed_data; import asyncio; asyncio.run(_seed_data())\"",
    "v2:install": "py -3.12 -m pip install -r backend/v2/requirements.txt",
    "v2:dev": "py -3.12 -m backend.v2.main",
    "v2:migrate": "py -3.12 -m backend.v2.database.migrations.run_up",
    "v2:seed": "py -3.12 -c \"import asyncio; from backend.v2.config import load_settings; from backend.v2.database.client import init_engine, create_tables; from backend.v2.database.seeds import seed_demo; settings = load_settings(); init_engine(settings); asyncio.run(create_tables()); asyncio.run(seed_demo(settings))\"",
    "v2:docker:up": "docker compose -f backend/v2/docker-compose.yml up -d",
    "v2:docker:down": "docker compose -f backend/v2/docker-compose.yml down",
    "v2:docker:logs": "docker compose -f backend/v2/docker-compose.yml logs -f",
    "v2:test": "py -3.12 -m pytest backend/v2/tests -v"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.21",
    "axios": "^1.13.6",
    "chai": "^6.2.2",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^2.1.8"
  }
}
